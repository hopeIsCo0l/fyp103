# Database: sqlite for dev, postgres for prod
DATABASE_URL=sqlite:///./recruit.db
SECRET_KEY=your-super-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
PASSWORD_RESET_EXPIRE_MINUTES=30

# OTP (dev: OTP is logged to console if SMTP not set)
OTP_EXPIRE_MINUTES=10
OTP_LENGTH=6
OTP_MAX_ATTEMPTS_PER_HOUR=5
SIGNIN_MAX_ATTEMPTS=5
SIGNIN_LOCK_MINUTES=15
SIGNIN_ATTEMPT_WINDOW_MINUTES=30
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# EMAIL_FROM=noreply@example.com
