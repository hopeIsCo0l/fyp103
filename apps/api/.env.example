# PostgreSQL — start DB: docker compose -f docker/docker-compose.yml up -d postgres
# Pytest uses database `recruit_test` on the same host/port (see docker/postgres-init/).
# Schema: `python init_db.py` or `alembic upgrade head` from apps/api (see README).
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5433/recruit_db
# Pytest sets this internally so the app skips DB bootstrap on import; leave unset when running the API.
# SKIP_STARTUP_DB=1
SECRET_KEY=your-super-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
PASSWORD_RESET_EXPIRE_MINUTES=30

# OTP (dev: OTP is logged to console if SMTP not set)
OTP_EXPIRE_MINUTES=10
OTP_LENGTH=6
OTP_MAX_ATTEMPTS_PER_HOUR=5
SIGNIN_MAX_ATTEMPTS=5
SIGNIN_LOCK_MINUTES=15
SIGNIN_ATTEMPT_WINDOW_MINUTES=30
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# EMAIL_FROM=noreply@example.com

# Super admin seed (used by seed_admin.py)
ADMIN_EMAIL=admin@recruit-system.com
ADMIN_PASSWORD=Admin123!
ADMIN_NAME=Super Admin

# Optional: external CV–job scorer HTTP API (base URL only; no trailing path).
# Host backend + scorer on Docker published port 8000: http://127.0.0.1:8000
# Backend in Docker + scorer on host: http://host.docker.internal:8000
# Same compose network as scorer: http://<service_name>:8000
# EA_CV_SCORER_URL=http://127.0.0.1:8000
# EA_CV_SCORER_TIMEOUT_SEC=5
