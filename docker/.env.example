# Copy to docker/.env and adjust (docker compose loads this automatically if named .env next to docker-compose.yml)

# PostgreSQL (host port 5433 -> container 5432)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=recruit_db

# API
SECRET_KEY=your-super-secret-key-change-in-production
SEED_ADMIN_ON_START=1
RUN_ALEMBIC=0

# Super admin (used when SEED_ADMIN_ON_START=1)
ADMIN_EMAIL=admin@recruit-system.com
ADMIN_PASSWORD=Admin123!
ADMIN_NAME=Super Admin

# Optional SMTP (uncomment in docker-compose backend environment if needed)
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# EMAIL_FROM=noreply@example.com
